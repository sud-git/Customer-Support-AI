    <label>Case</label>
    <listViews>
        <fullName>AllCases</fullName>
        <filterScope>Everything</filterScope>
        <label>All Cases</label>
    </listViews>
    <listViews>
        <fullName>OpenCases</fullName>
        <booleanFilter>1 OR 2</booleanFilter>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Case__c.Status__c</field>
            <operation>equals</operation>
            <value>New</value>
        </filters>
        <filters>
            <field>Case__c.Status__c</field>
            <operation>equals</operation>
            <value>In Progress</value>
        </filters>
        <label>Open Cases</label>
    </listViews>
    <listViews>
        <fullName>HighPriorityCases</fullName>
        <booleanFilter>1 OR 2</booleanFilter>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Case__c.Priority__c</field>
            <operation>equals</operation>
            <value>High</value>
        </filters>
        <filters>
            <field>Case__c.Priority__c</field>
            <operation>equals</operation>
            <value>Critical</value>
        </filters>
        <label>High Priority Cases</label>
    </listViews>
    <nameField>
        <displayFormat>CS-{00000000}</displayFormat>
        <label>Case Number</label>
        <trackHistory>true</trackHistory>
        <type>AutoNumber</type>
    </nameField>
